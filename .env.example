# Auth.js / NextAuth — generate with: openssl rand -base64 32
AUTH_SECRET=replace-with-a-long-random-string
# Optional (Auth.js also reads NEXTAUTH_URL)
# AUTH_URL=http://localhost:3000

# ——— Google ———
# https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: http://localhost:3000/api/auth/callback/google
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# ——— Facebook ———
# https://developers.facebook.com/apps/
# Valid OAuth Redirect URI: http://localhost:3000/api/auth/callback/facebook
AUTH_FACEBOOK_ID=
AUTH_FACEBOOK_SECRET=

# ——— GitHub ———
# https://github.com/settings/developers
# Callback: http://localhost:3000/api/auth/callback/github
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# ——— Discord ———
# https://discord.com/developers/applications
# Redirect: http://localhost:3000/api/auth/callback/discord
AUTH_DISCORD_ID=
AUTH_DISCORD_SECRET=

# ——— Apple (optional) ———
AUTH_APPLE_ID=
AUTH_APPLE_SECRET=

# ——— X / Twitter (optional) ———
AUTH_TWITTER_ID=
AUTH_TWITTER_SECRET=

# Email + password works with no OAuth keys (stored in .data/users.json)
